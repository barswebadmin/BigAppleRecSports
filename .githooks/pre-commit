#!/bin/bash
#
# Pre-commit hook for automatic version management and code quality checks
# Handles lambda function versioning only (backend versioning happens on merge/deploy)
#

set -e

echo "🔍 Running pre-commit checks..."

# Get the directory where this script is located (should be .githooks)
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
cd "$REPO_ROOT"

# 0. Block commits to main branch
CURRENT_BRANCH=$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "unknown")
if [ "$CURRENT_BRANCH" = "main" ]; then
    echo ""
    echo "❌❌❌ COMMIT BLOCKED ❌❌❌"
    echo ""
    echo "🚨 You are attempting to commit directly to the 'main' branch!"
    echo ""
    echo "This is not allowed for safety reasons."
    echo ""
    echo "Please:"
    echo "  1. Create a feature branch: git checkout -b feature/your-feature-name"
    echo "  2. Commit your changes to that branch"
    echo "  3. Create a pull request to merge into main"
    echo ""
    echo "Current branch: [RED]main[/RED]"
    echo ""
    exit 1
fi

# Nothing staged → nothing to check.
if git diff --cached --quiet; then
    echo "ℹ️  No staged changes; skipping pre-commit checks."
    exit 0
fi

# Check if we have python3 available
if ! command -v python3 &> /dev/null; then
    echo "⚠️  Warning: python3 not found. Skipping checks."
    exit 0
fi

