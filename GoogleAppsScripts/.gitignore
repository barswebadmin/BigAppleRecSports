# Build output
**/build/
**/deploy_temp/

# Generated .gs files (built from .js sources via esbuild)
**/*.gs

# Dependencies
**/node_modules/
# Keep root pnpm-lock.yaml but block ALL lock files and package.json from projects
projects/**/*lock*
projects/**/package.json

# Temporary deployment directories
**/deploy_temp/
**/.clasp_push_temp/
**/.clasp_pull_temp/
**/.clasp_pull_organized/
**/.clasp_push_compare/
**/.clasp_pull_compare/
**/.clasp_pull_build_compare/
**/.clasp_pull_backup/
**/pull_validation/
**/pull_review/
**/.deploy_temp/
**/test_clasp_temp/
**/test_deploy_temp/

# Clasp credentials and config
**/.clasprc.json
**/.remote-version

# Google Apps Script files that may contain secrets
**/*.json.bak

# Temporary files
**/*.tmp
**/*.log

# IDE files
**/.vscode/
**/.idea/

# OS files
**/.DS_Store
**/Thumbs.db
