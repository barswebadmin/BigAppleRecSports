{
  "nodeModulesDir": "auto",
  "compilerOptions": {
    "lib": ["deno.window"],
    "strict": true
  },
  "imports": {
    "@bars/firebase": "./shared/firebase_client.ts",
    "@bars/google": "./shared/google_client.ts",
    "@bars/shared/": "./shared/",
    "@std/assert": "jsr:@std/assert@^1.0.15",
    "@std/cache": "jsr:@std/cache@^0.2.3",
    "@std/collections": "jsr:@std/collections@^1.2.0",
    "@std/csv": "jsr:@std/csv@^1.0.6",
    "@std/datetime": "jsr:@std/datetime@^0.225.7",
    "@std/http": "jsr:@std/http@^1.0.25",
    "@std/testing": "jsr:@std/testing@^1.0.16",
    "@std/testing/mock": "jsr:@std/testing@^1.0.16/mock",
    "@std/text": "jsr:@std/text@^1.0.19",
    "@std/text/unstable-to-title-case": "jsr:@std/text@^1.0.19/unstable-to-title-case",
    "date-fns": "npm:date-fns@4",
    "deno-slack-api/": "https://deno.land/x/deno_slack_api@2.8.0/",
    "deno-slack-sdk/": "https://deno.land/x/deno_slack_sdk@2.15.1/",
    "firebase-admin/app": "npm:firebase-admin@^12.0.0/app",
    "firebase-admin/firestore": "npm:firebase-admin@^12.0.0/firestore",
    "google-auth-library": "npm:google-auth-library@^9.0.0",
    "googleapis": "npm:googleapis@^128.0.0",
    "jose": "https://deno.land/x/jose@v4.4.0/index.ts",
    "slack-block-builder": "npm:slack-block-builder@^2.8.0"
  },
  "exclude": ["node_modules"],
  "tasks": {
    "test-auth": "bash -c 'source ../.env && deno run --allow-net --allow-env --allow-read test_auth_simple.ts'",
    "test-auth-full": "bash -c 'source ../.env && deno run --allow-net --allow-env --allow-read test_shared_auth.ts'",
    "test-all": "bash -c 'source ../.env && deno test --allow-net --allow-read --allow-env'",
    "lint": "deno lint",
    "format": "deno fmt"
  }
}
