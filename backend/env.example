# Big Apple Rec Sports Backend Environment Variables
# Copy this file to .env and fill in your actual values

# Shopify Configuration (Production/Staging)
SHOPIFY_URL_ADMIN_DOMAIN=your-store.myshopify.com
SHOPIFY_TOKEN=shpat_your_shopify_access_token_here
SHOPIFY_LOCATION_ID=your_shopify_location_id
SHOPIFY_ADMIN_URL=https://admin.shopify.com/store/your-store-name

# Shopify Configuration (Development - Optional)
# If set, these will be used when ENVIRONMENT=dev/test
# If not set, will fallback to production credentials or use mocks
SHOPIFY_DEV_STORE=your-dev-store.myshopify.com
SHOPIFY_DEV_TOKEN=shpat_your_dev_shopify_access_token_here
SHOPIFY_DEV_LOCATION_ID=your_dev_shopify_location_id
SHOPIFY_DEV_ADMIN_URL=https://admin.shopify.com/store/your-dev-store-name

# Slack Bot Tokens and Signing Secrets
# Each bot has its own token and signing secret for security and permissions isolation
SLACK_BOT_TOKEN_DEV=xoxb-your-dev-bot-token-here
SLACK_SIGNING_SECRET_DEV=your-dev-signing-secret-here

SLACK_BOT_TOKEN_EXEC=xoxb-your-exec-bot-token-here
SLACK_SIGNING_SECRET_EXEC=your-exec-signing-secret-here

SLACK_BOT_TOKEN_LEADERSHIP=xoxb-your-leadership-bot-token-here
SLACK_SIGNING_SECRET_LEADERSHIP=your-leadership-signing-secret-here
# Optional: User Token for operations requiring User Token Scopes (e.g., users.profile:write)
# Get this by adding users.profile:write to User Token Scopes in Slack app settings and reinstalling
SLACK_BOT_USER_TOKEN_LEADERSHIP=xoxp-your-leadership-user-token-here

SLACK_BOT_TOKEN_PAYMENT_ASSISTANCE=xoxb-your-payment-assistance-bot-token-here
SLACK_SIGNING_SECRET_PAYMENT_ASSISTANCE=your-payment-assistance-signing-secret-here

SLACK_BOT_TOKEN_REFUNDS=xoxb-your-refunds-bot-token-here
SLACK_SIGNING_SECRET_REFUNDS=your-refunds-signing-secret-here

SLACK_BOT_TOKEN_REGISTRATIONS=xoxb-your-registrations-bot-token-here
SLACK_SIGNING_SECRET_REGISTRATIONS=your-registrations-signing-secret-here

SLACK_BOT_TOKEN_WEB=xoxb-your-web-bot-token-here
SLACK_SIGNING_SECRET_WEB=your-web-signing-secret-here

# Shopify Webhook Configuration
SHOPIFY_WEBHOOK_SECRET=your-shopify-webhook-secret-here

# Google Apps Script Web App URLs
GAS_WAITLIST_FORM_WEB_APP_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec
# GAS_REFUNDS_WEBHOOK_URL=https://script.google.com/macros/s/YOUR_REFUNDS_SCRIPT_ID/exec  # REMOVED: No longer using GAS for refund emails

# Google API Configuration
# Path to Google Service Account credentials JSON file (relative to backend/ directory)
# See GOOGLE_SHEETS_SETUP_GUIDE.md for setup instructions
GOOGLE.SERVICE_ACCOUNT_FILE=google-service-account.json
# Google Workspace admin email for domain-wide delegation (required for Directory API)
# This is the user email to impersonate when making API calls
# You can set this here OR add a "subject" field directly to google-service-account.json
# If both are set, this env var takes precedence
GOOGLE.SUBJECT=admin@bigapplerecsports.com

# AWS Lambda URLs for Product Scheduling
# These endpoints receive requests for scheduling inventory moves and price changes
AWS_SCHEDULE_PRODUCT_CHANGES_URL=https://your-lambda-url.lambda-url.us-east-1.on.aws/
AWS_PAYMENT_ASSISTANCE_URL=https://your-payment-lambda-url.lambda-url.us-east-1.on.aws/
AWS_CREATE_PRODUCT_ENDPOINT=https://your-product-lambda-url.lambda-url.us-east-1.on.aws/

# AWS Lambda URLs (Development - Optional)
# If set, these will be used when ENVIRONMENT=dev/test
AWS_DEV_SCHEDULE_PRODUCT_CHANGES_URL=https://your-dev-lambda-url.lambda-url.us-east-1.on.aws/
AWS_DEV_PAYMENT_ASSISTANCE_URL=https://your-dev-payment-lambda-url.lambda-url.us-east-1.on.aws/
AWS_DEV_CREATE_PRODUCT_ENDPOINT=https://your-dev-product-lambda-url.lambda-url.us-east-1.on.aws/

# Shopify REST API URL (optional - auto-generated if not set)
SHOPIFY_REST_URL=https://your-store.myshopify.com/admin/api/2024-04
SHOPIFY_DEV_REST_URL=https://your-dev-store.myshopify.com/admin/api/2024-04

# SSL Certificate Configuration (Development/Staging)
# Path to SSL certificate file for local development
# If not set, will use certifi package or system defaults
LOCAL_SSL_CERT_FILE=/path/to/your/local/certificate.pem

# Application Environment
# Controls SSL, API endpoints, tokens, and mocking behavior:
# - dev/test = Use mocks, certifi/local SSL, dev tokens (if available)
# - staging = Use production endpoints/tokens, local/certifi SSL
# - production = Use production endpoints/tokens, Ubuntu system SSL
ENVIRONMENT=dev

# Force Real API (Development Override)
# Set to 'true' to force real API calls even in dev/test environment
# FORCE_REAL_API=true

# Testing Configuration
# Tests will use these variables for integration testing
# If not set, tests will use safe defaults (test_token, test-store.myshopify.com)

# For production deployment on Render:
# - Set ENVIRONMENT=production
# - SHOPIFY_URL_ADMIN_DOMAIN must be set in Render environment variables
# - SHOPIFY_TOKEN must be set in Render environment variables
