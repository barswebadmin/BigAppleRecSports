{
  "description": "Shopify GraphQL Schema Filter - Exclude-Only Strategy (Reference Only)",
  "version": "2.0",
  "strategy": "exclude_only",
  "note": "This file is for documentation only. Edit EXCLUDE_TYPES in fetch_schema_filtered.py to change filtering.",
  
  "exclude_types": [
    "App",
    "AppInstallation",
    "AppSubscription",
    "AppPurchase",
    "AppCredit",
    "AppUsageRecord",
    "AppRevenueAttribution",
    "WebhookSubscription",
    "AbandonedCheckout",
    "Abandonment",
    "CheckoutProfile",
    "Blog",
    "Article",
    "Comment",
    "Page",
    "OnlineStorePage",
    "GiftCard",
    "GiftCardTransaction",
    "Market",
    "MarketLocalization",
    "MarketRegion",
    "CompanyLocation",
    "CompanyContact",
    "Company",
    "Function",
    "ShopifyFunction",
    "Validation",
    "ShopifyPaymentsDispute",
    "ShopifyPaymentsDisputeEvidence",
    "BulkOperation",
    "BulkMutation",
    "OnlineStoreTheme",
    "ShopLocale",
    "Domain",
    "ShopFeatures",
    "ShopPlan",
    "SavedSearch",
    "ScriptTag",
    "ShopResourceLimits",
    "Translation",
    "PrivateMetafield",
    "Channel",
    "Publication",
    "ResourcePublication"
  ],
  
  "what_gets_included": [
    "Everything else! Including:",
    "- Orders (Order, LineItem, Transaction, Refund, etc.)",
    "- Products (Product, ProductVariant, ProductImage, etc.)",
    "- Customers (Customer, CustomerSegment, etc.)",
    "- Discounts (Discount, DiscountCode, AutomaticDiscount, etc.)",
    "- Media (Media, Image, Video, File, etc.)",
    "- Money (Money, MoneyV2, MoneyBag, CurrencyCode, etc.)",
    "- Staff (StaffMember, ShopPolicy, etc.)",
    "- Fulfillment (Fulfillment, FulfillmentOrder, etc.)",
    "- Inventory (Inventory, InventoryItem, InventoryLevel, etc.)",
    "- And all their dependencies automatically!"
  ],
  
  "usage": {
    "how_to_customize": "Edit EXCLUDE_TYPES in scripts/shopify/fetch_shopify_gql_schema_filtered.py",
    "how_to_run": "python scripts/shopify/fetch_shopify_gql_schema_filtered.py --env production",
    "how_to_generate": "sgqlc-codegen schema shared_utilities/clients/shopify_client/shopify_schema_filtered.json shared_utilities/clients/shopify_client/shopify_schema_filtered.py",
    "documentation": "See shared_utilities/clients/shopify_client/README.md for full guide"
  }
}
