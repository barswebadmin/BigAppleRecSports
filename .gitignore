**/test_deploy_temp/
**/.deploy_temp/
*_temp.sh
test_*_temp.*

# TODO: fix the deploy process — clasp's rootDir points at deploy_temp/, which is
# just `build/` copied over (scripts/deploy rm -rf's + recreates it each run).
# It's generated output and shouldn't be a tracked/committed artifact.
**/deploy_temp/

# Google Apps Script build directories (generated by esbuild)
google-apps-scripts/**/build/
google-apps-scripts/**/build/**

# Planning documents (local working files)
SLACK_ARCHITECTURE_REFACTOR_PLAN.md

# Locksmith lock configs (may contain sensitive configuration)
